# ── Cấu hình môi trường Admin Web (Vite) ──
# LOCAL: copy file này thành ".env" rồi điền giá trị (file .env KHÔNG được commit).
# VERCEL: nhập 4 biến dưới đây trong Project Settings → Environment Variables.
#
# Lưu ý: mọi biến VITE_* sẽ bị "nướng" vào bundle phía client (ai cũng xem được),
# nên KHÔNG đặt secret thật sự nhạy cảm ở đây.

# Supabase (đọc thẳng các bảng: wallets, game_quests, game_achievements...)
VITE_SUPABASE_URL=https://qcxfmenzyzbzwwxrpsdm.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend .NET (các trang: Người Chơi, Giao Dịch, Dashboard, Vật Phẩm, Cấu Hình...)
# - LOCAL test: http://localhost:5042
# - PRODUCTION (Vercel): URL BE công khai, ví dụ https://be-sudaiviet.onrender.com
#   (BE phải đang chạy + đã thêm domain Vercel vào CORS thì các trang này mới có data)
VITE_API_BASE_URL=https://be-sudaiviet.onrender.com

# Khóa gọi API admin của BE (gửi qua header X-Admin-Key)
VITE_ADMIN_KEY=your_admin_key_here
